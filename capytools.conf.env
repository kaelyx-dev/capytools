# capytools system configuration
# shellcheck shell=bash
# All variables are prefixed with CAPY_ to avoid shell environment pollution.
# This file is versioned and distributed with each release.
# To override any value, set it in ~/.capytools/user-capytools.conf.env.

CAPY_GREETING="hello from capytools"
CAPY_COLOR_PROMPT="true"

# Version lock -- uncomment and set in user-capytools.conf.env to pin updates.
# When set, `capytools update` installs this version instead of the latest.
# Use `capytools lock <version>` / `capytools unlock` to manage this.
# CAPY_LOCK_VERSION=""

#CAPY_VSC_PATH=""
#CAPY_VSC_ARGS="--disable-gpu"